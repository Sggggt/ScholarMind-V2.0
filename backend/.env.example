# LLM runtime
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Local GGUF runtime metadata
LOCAL_LLM_ENGINE=lm-studio
LOCAL_LLM_SERVER_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL_PATH=
LOCAL_LLM_MODEL_ALIAS=local-gguf
LOCAL_LLM_CONTEXT_SIZE=4096
LOCAL_LLM_GPU_LAYERS=0

# Search providers
SEARCH_PROVIDER=brave
SEMANTIC_SCHOLAR_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Service
HOST=0.0.0.0
PORT=8000

# Sandbox
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=600
