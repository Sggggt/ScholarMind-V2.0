# LLM runtime
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Local GGUF runtime metadata
LOCAL_LLM_ENGINE=lm-studio
LOCAL_LLM_SERVER_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL_PATH=
LOCAL_LLM_MODEL_ALIAS=local-gguf
LOCAL_LLM_CONTEXT_SIZE=4096
LOCAL_LLM_GPU_LAYERS=0

# External Aider runtime (recommended: separate Python 3.11 env)
# Set either AIDER_PYTHON or AIDER_EXE
AIDER_PYTHON=
AIDER_EXE=

# Optional custom code workspace mapping for Docker.
# Docker default mode shares the repo parent directory automatically.
# Only set HOST_WORKDIR_ROOT when your custom directory is outside that shared root.
DOCKER_SHARED_WORKDIR_ROOT=/host-project-root
DOCKER_SHARED_WORKDIR_MARKER=Project
HOST_WORKDIR_ROOT=
CONTAINER_WORKDIR_ROOT=/external-workdir

# Search providers
SEARCH_PROVIDER=brave
SEMANTIC_SCHOLAR_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Service
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=
NGROK_API_URL=http://127.0.0.1:4040/api/tunnels

# CORS - Comma-separated list of allowed origins, or * for all origins
# Development: Allow all origins
ALLOWED_ORIGINS=*
# Production: Specify exact origins
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,https://yourdomain.com

# Sandbox
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=600
